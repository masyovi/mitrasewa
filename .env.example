# Database (local SQLite - development only)
DATABASE_URL="file:./db/custom.db"

# Turso Database (libsql) - for production / Vercel
TURSO_DATABASE_URL="libsql://your-turso-db-url.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# DeepSeek API (for Vercel) - get free key at https://platform.deepseek.com/
# Set this on Vercel env variables, NOT needed for local dev
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
